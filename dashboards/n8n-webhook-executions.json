{
  "uid": "n8n-webhook-executions",
  "title": "n8n Webhook Executions",
  "tags": [
    "n8n",
    "webhooks"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "workflow_name",
        "label": "Workflow",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(n8n_workflow_info, workflow_name)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Requests by Webhook Path \u2014 Success vs Failed",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (workflow_name, method, webhook_path) (increase(n8n_http_request_duration_seconds_count{path=\"/webhook/:path\", status_code=~\"[23]..\"}[$__rate_interval]) * on(workflow_id) group_left(workflow_name) n8n_workflow_info{workflow_name=~\"$workflow_name\"})",
          "legendFormat": "{{workflow_name}} / {{method}} / {{webhook_path}} \u2014 success"
        },
        {
          "refId": "B",
          "expr": "sum by (workflow_name, method, webhook_path) (increase(n8n_http_request_duration_seconds_count{path=\"/webhook/:path\", status_code=~\"[45]..\"}[$__rate_interval]) * on(workflow_id) group_left(workflow_name) n8n_workflow_info{workflow_name=~\"$workflow_name\"})",
          "legendFormat": "{{workflow_name}} / {{method}} / {{webhook_path}} \u2014 failed"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Executions",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(n8n_workflow_execution_duration_seconds_count{mode=\"webhook\"}[$__range]) * on(workflow_id) group_left() n8n_workflow_info{workflow_name=~\"$workflow_name\"})",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Successful Executions",
      "gridPos": {
        "x": 5,
        "y": 10,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(n8n_workflow_execution_duration_seconds_count{mode=\"webhook\", status=\"success\"}[$__range]) * on(workflow_id) group_left() n8n_workflow_info{workflow_name=~\"$workflow_name\"})",
          "legendFormat": "Success"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Failed Executions",
      "gridPos": {
        "x": 10,
        "y": 10,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(n8n_workflow_execution_duration_seconds_count{mode=\"webhook\", status=\"failed\"}[$__range]) * on(workflow_id) group_left() n8n_workflow_info{workflow_name=~\"$workflow_name\"})",
          "legendFormat": "Failed"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Success Rate",
      "gridPos": {
        "x": 15,
        "y": 10,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(n8n_workflow_execution_duration_seconds_count{mode=\"webhook\", status=\"success\"}[$__range]) * on(workflow_id) group_left() n8n_workflow_info{workflow_name=~\"$workflow_name\"}) / sum(increase(n8n_workflow_execution_duration_seconds_count{mode=\"webhook\"}[$__range]) * on(workflow_id) group_left() n8n_workflow_info{workflow_name=~\"$workflow_name\"})",
          "legendFormat": "Success Rate"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Current Requests / min",
      "gridPos": {
        "x": 20,
        "y": 10,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(n8n_http_request_duration_seconds_count{path=\"/webhook/:path\"}[$__rate_interval]) * on(workflow_id) group_left() n8n_workflow_info{workflow_name=~\"$workflow_name\"}) * 60",
          "legendFormat": "req/min"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Execution Duration \u2014 p50 / p90 / p99",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(n8n_workflow_execution_duration_seconds_bucket{mode=\"webhook\"}[$__rate_interval]) * on(workflow_id) group_left() n8n_workflow_info{workflow_name=~\"$workflow_name\"}))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.90, sum by (le) (rate(n8n_workflow_execution_duration_seconds_bucket{mode=\"webhook\"}[$__rate_interval]) * on(workflow_id) group_left() n8n_workflow_info{workflow_name=~\"$workflow_name\"}))",
          "legendFormat": "p90"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(n8n_workflow_execution_duration_seconds_bucket{mode=\"webhook\"}[$__rate_interval]) * on(workflow_id) group_left() n8n_workflow_info{workflow_name=~\"$workflow_name\"}))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top Workflows",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "sortBy": [
          {
            "desc": true,
            "displayName": "Count"
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "workflow_id": "Workflow ID",
              "workflow_name": "Workflow Name",
              "Value": "Count"
            },
            "indexByName": {
              "workflow_id": 0,
              "workflow_name": 1,
              "Value": 2
            },
            "excludeByName": {}
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (workflow_id, workflow_name) (increase(n8n_http_request_duration_seconds_count{path=\"/webhook/:path\"}[$__range]) * on(workflow_id) group_left(workflow_name) n8n_workflow_info{workflow_name=~\"$workflow_name\"})",
          "instant": true,
          "range": false,
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Average Execution Time per Webhook URL",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (workflow_name, method, webhook_path) (rate(n8n_http_request_duration_seconds_sum{path=\"/webhook/:path\"}[$__rate_interval]) * on(workflow_id) group_left(workflow_name) n8n_workflow_info{workflow_name=~\"$workflow_name\"}) / sum by (workflow_name, method, webhook_path) (rate(n8n_http_request_duration_seconds_count{path=\"/webhook/:path\"}[$__rate_interval]) * on(workflow_id) group_left(workflow_name) n8n_workflow_info{workflow_name=~\"$workflow_name\"})",
          "legendFormat": "{{workflow_name}} / {{method}} / {{webhook_path}}"
        }
      ]
    }
  ]
}