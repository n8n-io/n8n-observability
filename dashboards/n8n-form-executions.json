{
  "uid": "n8n-form-executions",
  "title": "n8n Form Executions",
  "tags": [
    "n8n",
    "forms"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "workflow_name",
        "label": "Workflow",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(n8n_workflow_info, workflow_name)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "n8n_base_url",
        "label": "Environment",
        "type": "custom",
        "query": "Local : http://localhost:5678",
        "options": [
          {
            "text": "Local",
            "value": "http://localhost:5678",
            "selected": true
          }
        ],
        "current": {
          "text": "Local",
          "value": "http://localhost:5678",
          "selected": true
        }
      }
    ]
  },
  "panels": [
    {
      "id": 7,
      "type": "timeseries",
      "title": "Form Submissions by Form Path — Success vs Failed",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (workflow_name, form_path) (increase(n8n_form_submission_duration_seconds_count{status_code=~\"[23]..\"}[$__rate_interval]) * on(workflow_id) group_left(workflow_name) max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"}))",
          "legendFormat": "{{workflow_name}} / {{form_path}} — success"
        },
        {
          "refId": "B",
          "expr": "sum by (workflow_name, form_path) (increase(n8n_form_submission_duration_seconds_count{status_code=~\"[45]..\"}[$__rate_interval]) * on(workflow_id) group_left(workflow_name) max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"}))",
          "legendFormat": "{{workflow_name}} / {{form_path}} — failed"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Submissions",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(n8n_form_submission_duration_seconds_count[$__range]) * on(workflow_id) group_left() max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"}))",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Successful Submissions",
      "gridPos": {
        "x": 5,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(n8n_form_submission_duration_seconds_count{status_code=~\"[23]..\"}[$__range]) * on(workflow_id) group_left() max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"}))",
          "legendFormat": "Success"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Failed Submissions",
      "gridPos": {
        "x": 10,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(n8n_form_submission_duration_seconds_count{status_code=~\"[45]..\"}[$__range]) * on(workflow_id) group_left() max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"}))",
          "legendFormat": "Failed"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Success Rate",
      "gridPos": {
        "x": 15,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(n8n_form_submission_duration_seconds_count{status_code=~\"[23]..\"}[$__range]) * on(workflow_id) group_left() max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"})) / sum(increase(n8n_form_submission_duration_seconds_count[$__range]) * on(workflow_id) group_left() max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"}))",
          "legendFormat": "Success Rate"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Current Submissions / min",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(n8n_form_submission_duration_seconds_count[$__rate_interval]) * on(workflow_id) group_left() max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"})) * 60",
          "legendFormat": "req/min"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Submission Duration — p50 / p90 / p99",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(n8n_form_submission_duration_seconds_bucket[$__rate_interval]) * on(workflow_id) group_left() max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"})))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.90, sum by (le) (rate(n8n_form_submission_duration_seconds_bucket[$__rate_interval]) * on(workflow_id) group_left() max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"})))",
          "legendFormat": "p90"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(n8n_form_submission_duration_seconds_bucket[$__rate_interval]) * on(workflow_id) group_left() max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"})))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top Workflows",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Workflow Name"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open workflow in n8n",
                    "url": "${n8n_base_url}/workflow/${__data.fields[\"workflow_id\"]}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "workflow_id"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "desc": true,
            "displayName": "Count"
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "workflow_name": "Workflow Name",
              "Value": "Count"
            },
            "indexByName": {
              "workflow_name": 0,
              "Value": 1
            },
            "excludeByName": {
              "Time": true
            }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (workflow_id, workflow_name) (increase(n8n_form_submission_duration_seconds_count[$__range]) * on(workflow_id) group_left(workflow_name) max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"}))",
          "instant": true,
          "range": false,
          "legendFormat": "",
          "format": "table"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Average Submission Time per Form Path",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (workflow_name, form_path) (rate(n8n_form_submission_duration_seconds_sum[$__rate_interval]) * on(workflow_id) group_left(workflow_name) max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"})) / sum by (workflow_name, form_path) (rate(n8n_form_submission_duration_seconds_count[$__rate_interval]) * on(workflow_id) group_left(workflow_name) max by (workflow_id, workflow_name) (n8n_workflow_info{workflow_name=~\"$workflow_name\"}))",
          "legendFormat": "{{workflow_name}} / {{form_path}}"
        }
      ]
    }
  ]
}
